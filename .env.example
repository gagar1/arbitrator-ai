# Arbitrator AI - Environment Configuration Template
# Copy this file to .env and fill in your actual values

# =============================================================================
# API KEYS - NEVER COMMIT ACTUAL KEYS TO VERSION CONTROL
# =============================================================================
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# =============================================================================
# APPLICATION SECURITY
# =============================================================================
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_SECRET_KEY=your_secret_key_here
JWT_SECRET_KEY=your_jwt_secret_here
ENCRYPTION_KEY=your_encryption_key_here

# API Authentication
API_KEY_HEADER=X-API-Key
API_RATE_LIMIT=100  # requests per minute

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================
ENVIRONMENT=development  # development, staging, production
DEBUG=false
LOG_LEVEL=INFO

# Server Configuration
API_HOST=0.0.0.0
API_PORT=8000
WORKERS=4
MAX_CONNECTIONS=1000

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
CORS_ALLOW_CREDENTIALS=true

# =============================================================================
# AI MODEL CONFIGURATION
# =============================================================================
DEFAULT_AI_PROVIDER=anthropic

# Anthropic Configuration
ANTHROPIC_MODEL=claude-3-sonnet-20240229
ANTHROPIC_TEMPERATURE=0.7
ANTHROPIC_MAX_TOKENS=4000
ANTHROPIC_TIMEOUT=30

# OpenAI Configuration
OPENAI_MODEL=gpt-4
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=4000
OPENAI_TIMEOUT=30

# Gemini Configuration
GEMINI_MODEL=gemini-pro
GEMINI_TEMPERATURE=0.7
GEMINI_MAX_TOKENS=4000
GEMINI_TIMEOUT=30

# =============================================================================
# RAG ENGINE CONFIGURATION
# =============================================================================
RAG_COLLECTION_NAME=arbitrator_docs
RAG_EMBEDDING_MODEL=all-MiniLM-L6-v2
RAG_PERSIST_DIR=./data/chroma_db
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=200
RAG_TOP_K=5
RAG_SIMILARITY_THRESHOLD=0.7

# Document Processing
MAX_DOCUMENT_SIZE_MB=50
MAX_BATCH_SIZE=100
PROCESSING_TIMEOUT=300

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# Vector Database
VECTOR_DB_TYPE=chromadb  # chromadb, pinecone, weaviate
VECTOR_DB_HOST=localhost
VECTOR_DB_PORT=8000

# Optional: PostgreSQL for metadata
# DATABASE_URL=postgresql://user:password@localhost:5432/arbitrator_ai
# DB_POOL_SIZE=10
# DB_MAX_OVERFLOW=20

# =============================================================================
# CACHING CONFIGURATION
# =============================================================================
# Redis Configuration
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=
REDIS_MAX_CONNECTIONS=10
CACHE_TTL=3600  # seconds

# =============================================================================
# OBSERVABILITY & MONITORING
# =============================================================================
# OpenTelemetry Configuration
OTEL_ENABLED=true
OTEL_SERVICE_NAME=arbitrator-ai
OTEL_SERVICE_VERSION=1.0.0
OTEL_ENVIRONMENT=development

# Jaeger Tracing
JAEGER_ENDPOINT=http://localhost:14268/api/traces
JAEGER_AGENT_HOST=localhost
JAEGER_AGENT_PORT=6831

# Prometheus Metrics
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
METRICS_ENDPOINT=/metrics

# Logging Configuration
LOG_FORMAT=json  # json, text
LOG_FILE_PATH=./logs/arbitrator-ai.log
LOG_MAX_SIZE_MB=100
LOG_BACKUP_COUNT=5
LOG_ROTATION_INTERVAL=daily

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================
# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=100
RATE_LIMIT_BURST=20

# Security Headers
SECURITY_HEADERS_ENABLED=true
HSTS_MAX_AGE=31536000
CSP_ENABLED=true

# Input Validation
MAX_REQUEST_SIZE_MB=10
MAX_QUERY_LENGTH=1000
SANITIZE_INPUT=true

# =============================================================================
# EXTERNAL SERVICES
# =============================================================================
# Weather API
WEATHER_API_KEY=your_weather_api_key
WEATHER_API_URL=https://api.openweathermap.org/data/2.5

# Shipping APIs
FEDEX_API_KEY=your_fedex_api_key
UPS_API_KEY=your_ups_api_key
DHL_API_KEY=your_dhl_api_key
USPS_API_KEY=your_usps_api_key

# =============================================================================
# DEVELOPMENT & TESTING
# =============================================================================
# Testing Configuration
TEST_DATABASE_URL=sqlite:///./test.db
TEST_REDIS_URL=redis://localhost:6379/1
TEST_API_KEY=test_api_key_123

# Development Tools
RELOAD_ON_CHANGE=true
DEBUG_TOOLBAR=false
PROFILING_ENABLED=false

# =============================================================================
# PRODUCTION SETTINGS
# =============================================================================
# SSL/TLS
SSL_ENABLED=false
SSL_CERT_PATH=./certs/cert.pem
SSL_KEY_PATH=./certs/key.pem

# Health Checks
HEALTH_CHECK_INTERVAL=30
HEALTH_CHECK_TIMEOUT=5

# Backup Configuration
BACKUP_ENABLED=false
BACKUP_INTERVAL=daily
BACKUP_RETENTION_DAYS=30
BACKUP_S3_BUCKET=arbitrator-ai-backups